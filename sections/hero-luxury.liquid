<!-- LUXURY HERO SECTION -->
<section class="hero">
  <img src="https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=1600&h=900&fit=crop" alt="Luxury Jewelry" class="hero__image">
  <div class="hero__content">
    <h1 class="hero__title">Timeless Elegance</h1>
    <p class="hero__subtitle">Premium jewelry crafted for extraordinary moments</p>
    <a href="/collections/all" class="button button--gold button--lg hero__cta">Explore Collection</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: #111111;
    margin-top: 80px;
  }

  .hero__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #F9F8F6;
    max-width: 700px;
    padding: 2rem;
  }

  .hero__title {
    color: #F9F8F6;
    font-size: 4rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    letter-spacing: -1px;
    animation: fadeInUp 0.8s ease-out;
  }

  .hero__subtitle {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 2rem;
    font-weight: 300;
    letter-spacing: 0.5px;
    animation: fadeInUp 0.8s ease-out 0.2s both;
  }

  .hero__cta {
    animation: fadeInUp 0.8s ease-out 0.4s both;
  }

  @media (max-width: 768px) {
    .hero {
      height: 60vh;
      margin-top: 70px;
    }

    .hero__title {
      font-size: 2.5rem;
    }

    .hero__subtitle {
      font-size: 1rem;
    }
  }
</style>

{% schema %}
{
  "name": "Hero Luxury",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "Timeless Elegance"},
    {"type": "text", "id": "subheading", "label": "Subheading", "default": "Premium jewelry crafted for extraordinary moments"},
    {"type": "image_picker", "id": "image", "label": "Background image"}
  ],
  "blocks": [],
  "presets": [{"name": "Hero Luxury"}]
}
{% endschema %}
