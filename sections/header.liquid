<header class="header" data-header>
  <div class="header__logo">
    <a href="/">
      {% if shop.brand.logo %}
        <img src="{{ shop.brand.logo | img_url: '50x50' }}" alt="{{ shop.name }}">
      {% endif %}
      <span>{{ shop.name }}</span>
    </a>
  </div>

  <nav class="header__nav" data-nav-primary>
    <ul class="nav-primary">
      <li class="nav-primary__item">
        <a href="/collections/necklaces" class="nav-primary__link">Necklaces</a>
        <div class="mega-menu">
          <div class="mega-menu__column">
            <h4 class="mega-menu__title">Necklaces</h4>
            <ul class="mega-menu__list">
              <li class="mega-menu__item"><a href="/collections/gold-necklaces" class="mega-menu__link">Gold Necklaces</a></li>
              <li class="mega-menu__item"><a href="/collections/silver-necklaces" class="mega-menu__link">Silver Necklaces</a></li>
              <li class="mega-menu__item"><a href="/collections/pendant-necklaces" class="mega-menu__link">Pendants</a></li>
            </ul>
          </div>
        </div>
      </li>
      <li class="nav-primary__item">
        <a href="/collections/bracelets" class="nav-primary__link">Bracelets</a>
        <div class="mega-menu">
          <div class="mega-menu__column">
            <h4 class="mega-menu__title">Bracelets</h4>
            <ul class="mega-menu__list">
              <li class="mega-menu__item"><a href="/collections/tennis-bracelets" class="mega-menu__link">Tennis</a></li>
              <li class="mega-menu__item"><a href="/collections/chain-bracelets" class="mega-menu__link">Chains</a></li>
            </ul>
          </div>
        </div>
      </li>
      <li class="nav-primary__item">
        <a href="/collections/rings" class="nav-primary__link">Rings</a>
      </li>
      <li class="nav-primary__item">
        <a href="/collections/earrings" class="nav-primary__link">Earrings</a>
      </li>
      <li class="nav-primary__item">
        <a href="/collections/best-sellers" class="nav-primary__link">Best Sellers</a>
      </li>
    </ul>
  </nav>

  <div class="header__actions">
    <button class="header__icon" data-search-toggle aria-label="Search">
      <svg viewBox="0 0 24 24"><path d="M15.5 1h-8C6.12 1 5 2.12 5 3.5v17C5 21.88 6.12 23 7.5 23h8c1.38 0 2.5-1.12 2.5-2.5v-17C18 2.12 16.88 1 15.5 1z"/></svg>
    </button>
    <button class="header__icon" data-account-toggle aria-label="Account">
      <svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
    </button>
    <button class="header__icon" data-cart-toggle aria-label="Shopping Bag">
      <svg viewBox="0 0 24 24"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>
    </button>
  </div>
</header>

<script>
  // Header scroll effect
  window.addEventListener('scroll', function() {
    const header = document.querySelector('[data-header]');
    if (window.scrollY > 50) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }
  });
</script>
