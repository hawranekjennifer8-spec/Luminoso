<!-- COLLECTION PAGE -->
<main id="main" role="main" class="main-content">
  <div class="collection-hero">
    <div class="collection-hero__content">
      <h1 class="collection-hero__title">{{ collection.title }}</h1>
      {% if collection.description %}
        <p class="collection-hero__description">{{ collection.description }}</p>
      {% endif %}
    </div>
  </div>

  <section class="collection-section">
    <div class="container">
      <div class="collection-toolbar">
        <div class="collection-toolbar__count">
          <span class="collection-count">{{ collection.products_count }} Produkte</span>
        </div>
        <div class="collection-toolbar__sort">
          <label for="sort-select" class="collection-toolbar__label">Sortieren:</label>
          <select id="sort-select" class="collection-toolbar__select" onchange="location = this.value;">
            <option value="{{ collection.url }}">Empfohlen</option>
            <option value="{{ collection.url }}?sort_by=price-ascending">Preis: Niedrig → Hoch</option>
            <option value="{{ collection.url }}?sort_by=price-descending">Preis: Hoch → Niedrig</option>
            <option value="{{ collection.url }}?sort_by=title-ascending">Name: A → Z</option>
            <option value="{{ collection.url }}?sort_by=title-descending">Name: Z → A</option>
          </select>
        </div>
      </div>

      {% if collection.products.size > 0 %}
        <div class="product-grid product-grid--max-columns-4">
          {% for product in collection.products %}
            <article class="product-card scroll-reveal">
              <a href="{{ product.url }}" class="product-card__link">
                {% if product.featured_image %}
                  <div class="product-card__image">
                    <img 
                      src="{{ product.featured_image | img_url: '600x600' }}" 
                      alt="{{ product.title }}"
                      loading="lazy"
                    >
                  </div>
                {% endif %}
                <div class="product-card__meta">
                  <h3 class="product-card__title">{{ product.title }}</h3>
                  <p class="product-card__vendor">{{ product.vendor }}</p>
                  <div class="product-card__price">
                    {% if product.compare_at_price_max > product.price_max %}
                      <span class="product-card__price--original">{{ product.compare_at_price_max | money }}</span>
                      <span class="product-card__price--sale">{{ product.price_max | money }}</span>
                    {% else %}
                      <span>{{ product.price_max | money }}</span>
                    {% endif %}
                  </div>
                </div>
              </a>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-collection">
          <p>Diese Kollektion ist derzeit leer.</p>
        </div>
      {% endif %}
    </div>
  </section>
</main>

<style>
  .collection-hero {
    background: linear-gradient(135deg, #050505 0%, #1a1a1a 100%);
    padding: 4rem 2rem;
    text-align: center;
    color: #F9F8F6;
    margin-top: 80px;
  }

  .collection-hero__title {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -1px;
  }

  .collection-hero__description {
    font-size: 1.1rem;
    color: rgba(249, 248, 246, 0.82);
    max-width: 720px;
    margin: 0 auto;
  }

  .collection-section {
    padding: 3rem 0;
  }

  .collection-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding: 0 1rem;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .collection-count {
    color: rgba(249, 248, 246, 0.82);
    font-size: 0.95rem;
  }

  .collection-toolbar__sort {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .collection-toolbar__label {
    color: rgba(249, 248, 246, 0.82);
    font-size: 0.95rem;
  }

  .collection-toolbar__select {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #F9F8F6;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .collection-toolbar__select:hover,
  .collection-toolbar__select:focus {
    border-color: #D4AF37;
    outline: none;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1rem;
    border-radius: 8px;
    transition: all 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-8px);
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.04);
  }

  .product-card__image {
    overflow: hidden;
    border-radius: 12px;
    margin-bottom: 1rem;
    aspect-ratio: 1;
  }

  .product-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .product-card:hover .product-card__image img {
    transform: scale(1.08);
  }

  .product-card__title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #F9F8F6;
    margin-bottom: 0.5rem;
  }

  .product-card__vendor {
    font-size: 0.9rem;
    color: rgba(249, 248, 246, 0.65);
    margin-bottom: 0.75rem;
  }

  .product-card__price {
    font-weight: 600;
    color: #F9F8F6;
  }

  .product-card__price--original {
    text-decoration: line-through;
    color: rgba(249, 248, 246, 0.55);
    margin-right: 0.5rem;
  }

  .empty-collection {
    text-align: center;
    padding: 4rem 2rem;
    color: rgba(249, 248, 246, 0.65);
  }

  @media (max-width: 768px) {
    .collection-hero {
      padding: 3rem 1.5rem;
    }

    .collection-toolbar {
      flex-direction: column;
      align-items: flex-start;
    }

    .product-grid {
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1.5rem;
    }
  }
</style>
